PORT=3001
MONGODB_URI=mongodb+srv://ai-no-code:<YOUR_PASSWORD>@cluster0.dau6aiq.mongodb.net/?appName=Cluster0
DB_NAME=ai-nocode-studio
JWT_SECRET=<YOUR_JWT_SECRET>
JWT_EXPIRES_IN=1h

# Optional: base URL of the SPA (used only when PASSWORD_RESET_LOG_LINK=true in development)
